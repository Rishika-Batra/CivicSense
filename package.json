{
  "name": "civicsense-monorepo",
  "version": "1.0.0",
  "description": "CivicSense Monorepo: Client, Server, and AI Service",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
