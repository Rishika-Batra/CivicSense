# Server environment variables
# Copy this file to .env for local development
# On Render, set these in your service's Environment tab

# ─── Core ─────────────────────────────────────────────────────────────────────

# Port the Express server listens on
# Render automatically injects PORT=10000; this is the local fallback
PORT=5000

# Node environment — must be "production" on Render
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:      mongodb://localhost:27017/civicsense
# Production: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/civicsense?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/civicsense

# ─── Authentication ───────────────────────────────────────────────────────────

# Secret key used to sign JWT tokens. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# ─── First Admin Seeding ──────────────────────────────────────────────────────

# Email and Password for seeding the initial admin account
ADMIN_EMAIL=admin@civicsense.gov
ADMIN_PASSWORD=secure_admin_password_123

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of permitted frontend origins
# Local:      http://localhost:5173
# Production: https://civicsense.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────────

# Create a free account at https://cloudinary.com and find these in your dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── AI Service ───────────────────────────────────────────────────────────────

# Base URL of the FastAPI AI service
# Local:      http://localhost:8000
# Production: https://civicsense-ai.onrender.com
AI_SERVICE_URL=http://localhost:8000
